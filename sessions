#!/usr/bin/env python3
"""sessions: browse and resume Claude Code sessions across all projects.

Lists every session under ~/.claude/projects/, grouped by workspace project,
with a readable description, and lets you jump back in via fzf. Solves the
cwd-scoping problem of built-in `claude -r`.
"""

import argparse
import json
import os
import re
import shlex
import shutil
import subprocess
import sys
import tempfile
import time
from collections import defaultdict
from pathlib import Path

HOME = Path.home()
PROJECTS_DIR = HOME / ".claude" / "projects"
CACHE_DIR = HOME / ".cache" / "sessions"
CACHE_FILE = CACHE_DIR / "index.json"
CACHE_TTL = 300  # 5 min

WORKSPACE_PREFIX = (
    HOME
    / "Library/CloudStorage/GoogleDrive-thomas@cfo-team.de/My Drive/Claude Workspace "
)

COMMAND_PREFIXES = ("<command-name>", "<local-command-stdout>", "<local-command-stderr>")
SYSTEM_MARKER = "<system-reminder>"
CLEAR_COMMAND = "/clear"


def extract_message_text(msg):
    c = msg.get("content", "") if isinstance(msg, dict) else ""
    if isinstance(c, str):
        return c
    if isinstance(c, list):
        return " ".join(
            x.get("text", "")
            for x in c
            if isinstance(x, dict) and x.get("type") == "text"
        )
    return ""


def is_noise_text(text):
    if not text:
        return True
    stripped = text.lstrip()
    if stripped.startswith(COMMAND_PREFIXES):
        return True
    if SYSTEM_MARKER in stripped[:200]:
        return True
    if stripped.rstrip() == CLEAR_COMMAND:
        return True
    return False


def scan_session(path):
    session_id = path.stem
    cwd = None
    git_branch = None
    custom_title = None
    first_prompt = None

    try:
        with path.open() as fh:
            for line in fh:
                try:
                    r = json.loads(line)
                except json.JSONDecodeError:
                    continue
                t = r.get("type")
                if t == "custom-title":
                    # latest one wins (matches how `claude -n` / /name overrides)
                    custom_title = r.get("customTitle") or custom_title
                if not cwd and r.get("cwd"):
                    cwd = r.get("cwd")
                    git_branch = r.get("gitBranch") or git_branch
                if t == "user" and not r.get("isMeta") and not first_prompt:
                    txt = extract_message_text(r.get("message", {}))
                    if not is_noise_text(txt):
                        first_prompt = txt.strip()
    except OSError:
        return None

    try:
        stat = path.stat()
    except OSError:
        return None

    return {
        "session_id": session_id,
        "cwd": cwd,
        "git_branch": git_branch,
        "custom_title": custom_title,
        "first_prompt": first_prompt,
        "mtime": stat.st_mtime,
        "size": stat.st_size,
        "path": str(path),
    }


def project_label(cwd):
    if not cwd:
        return "unknown"
    prefix = str(WORKSPACE_PREFIX)
    prefix_rstripped = prefix.rstrip()
    cwd_rstripped = cwd.rstrip("/")
    if cwd_rstripped == prefix_rstripped or cwd == prefix:
        return "workspace-root"
    if cwd.startswith(prefix):
        rest = cwd[len(prefix):].strip("/")
        parts = [p for p in rest.split("/") if p]
        if not parts:
            return "workspace-root"
        return "/".join(parts[:2]) if len(parts) >= 2 else parts[0]
    # outside workspace
    return f"external/{Path(cwd).name}"


def human_time_ago(mtime):
    delta = time.time() - mtime
    if delta < 60:
        return "just now"
    if delta < 3600:
        return f"{int(delta / 60)}m ago"
    if delta < 86400:
        return f"{int(delta / 3600)}h ago"
    if delta < 86400 * 7:
        return f"{int(delta / 86400)}d ago"
    if delta < 86400 * 30:
        return f"{int(delta / 86400 / 7)}w ago"
    return f"{int(delta / 86400 / 30)}mo ago"


def absolute_date(mtime):
    if not mtime:
        return "        "
    return time.strftime("[%d.%m.]", time.localtime(mtime))


def build_index(force_refresh=False):
    CACHE_DIR.mkdir(parents=True, exist_ok=True)

    if not force_refresh and CACHE_FILE.exists():
        try:
            cache_mtime = CACHE_FILE.stat().st_mtime
            if time.time() - cache_mtime < CACHE_TTL:
                newest_jsonl = 0.0
                for p in PROJECTS_DIR.glob("*/*.jsonl"):
                    try:
                        newest_jsonl = max(newest_jsonl, p.stat().st_mtime)
                    except OSError:
                        pass
                if newest_jsonl < cache_mtime:
                    return json.loads(CACHE_FILE.read_text())
        except (OSError, json.JSONDecodeError):
            pass

    sessions = []
    for p in PROJECTS_DIR.glob("*/*.jsonl"):
        info = scan_session(p)
        if info:
            info["project"] = project_label(info.get("cwd"))
            sessions.append(info)

    try:
        CACHE_FILE.write_text(json.dumps(sessions))
    except OSError:
        pass
    return sessions


def filter_sessions(sessions, args):
    out = []
    cutoff = None
    if not args.all and args.days:
        cutoff = time.time() - args.days * 86400

    for s in sessions:
        if not args.include_empty and not args.all:
            # Empty = no real user prompt, even if session was named via `claude -n`.
            # Matches plan definition: session must contain a real user message.
            if not s.get("first_prompt"):
                continue
        if cutoff and s.get("mtime", 0) < cutoff:
            continue
        if args.project and args.project.lower() not in s.get("project", "").lower():
            continue
        out.append(s)
    return out


def apply_caps(sessions, args, sort_mode="project"):
    per_group_cap = args.per_group
    # Time view is a flat list — no per-project grouping, so no per-group cap.
    if args.all or args.project or sort_mode == "time":
        per_group_cap = 0

    sessions.sort(key=lambda s: s.get("mtime", 0), reverse=True)

    groups = defaultdict(list)
    for s in sessions:
        groups[s.get("project", "unknown")].append(s)

    displayed = []
    overflow_by_group = {}
    for project, items in groups.items():
        if per_group_cap and len(items) > per_group_cap:
            displayed.extend(items[:per_group_cap])
            overflow_by_group[project] = len(items) - per_group_cap
        else:
            displayed.extend(items)

    displayed.sort(key=lambda s: s.get("mtime", 0), reverse=True)

    global_ceiling = None if args.all else 300
    total_overflow = 0
    if global_ceiling and len(displayed) > global_ceiling:
        total_overflow = len(displayed) - global_ceiling
        displayed = displayed[:global_ceiling]

    return displayed, overflow_by_group, total_overflow


def strip_leading_hashtag(s):
    # Drop a leading "#tag" / "# Task" prefix; mid-text hashtags untouched.
    return re.sub(r"^\s*#\s*\w+\s+", "", s)


def format_row(s, label_width=38, max_width=None):
    label = f"[{s['project']}]"
    if len(label) > label_width:
        label = label[: label_width - 1] + "]"
    label = label.ljust(label_width)
    time_ago = human_time_ago(s.get("mtime", 0)).rjust(8)
    date_str = absolute_date(s.get("mtime", 0))
    desc = s.get("first_prompt") or s.get("custom_title") or "(empty session)"
    desc = re.sub(r"\[Image #\d+\]", "", desc)
    desc = re.sub(r"\s+", " ", desc).strip()
    desc = strip_leading_hashtag(desc)
    row = f"{label}  {time_ago}  {date_str}   {desc}"
    # When the caller knows the terminal width (cmd_list), trim so a row never
    # wraps. fzf does its own per-pane truncation, so we leave rows full-length
    # in the picker path and let fzf handle it (and resize handling).
    if max_width is not None and len(row) > max_width:
        row = row[: max_width - 1] + "…"
    return row


def render_rows(sessions, overflow_by_group, total_overflow,
                for_fzf=False, max_width=None, sort_mode="project"):
    lines = []

    if sort_mode == "time":
        # Flat list, sorted by mtime. fzf default layout puts the FIRST input row
        # at the bottom near the prompt, so for fzf we feed newest-first (DESC).
        # For plain stdout, the user reads top-down, so we reverse to ASC so the
        # newest line lands at the bottom of the output.
        ordered = sorted(sessions, key=lambda s: s.get("mtime", 0), reverse=for_fzf)
        for s in ordered:
            row = format_row(s, max_width=max_width)
            if for_fzf:
                lines.append(f"{s['session_id']}\t{row}")
            else:
                lines.append(row)
        if total_overflow:
            if for_fzf:
                footer = f"    … {total_overflow} more session(s) truncated — press Space to expand"
                lines.append(f"__OVERFLOW_GLOBAL__\t{footer}")
            else:
                lines.append(f"    … {total_overflow} more session(s) truncated — use --all")
        return lines

    # project mode: clustered by project, groups ordered by recent activity
    grouped = defaultdict(list)
    for s in sessions:
        grouped[s["project"]].append(s)

    sorted_groups = sorted(
        grouped.items(),
        key=lambda kv: -max(s.get("mtime", 0) for s in kv[1]),
    )

    for project, items in sorted_groups:
        for s in items:
            row = format_row(s, max_width=max_width)
            if for_fzf:
                lines.append(f"{s['session_id']}\t{row}")
            else:
                lines.append(row)
        if project in overflow_by_group:
            count = overflow_by_group[project]
            if for_fzf:
                footer = f"    … {count} older session(s) in {project} — press Space to expand"
                lines.append(f"__OVERFLOW_PROJECT__{project}\t{footer}")
            else:
                lines.append(
                    f"    … {count} older session(s) in {project}"
                    f" — use --project {project} --all"
                )

    if total_overflow:
        if for_fzf:
            footer = f"    … {total_overflow} more session(s) truncated — press Space to expand"
            lines.append(f"__OVERFLOW_GLOBAL__\t{footer}")
        else:
            lines.append(f"    … {total_overflow} more session(s) truncated — use --all")

    return lines


def build_projects(sessions):
    # Aggregate to one row per unique cwd. Ignores sessions with no recorded
    # cwd (can't open a new session there). No --days / --include-empty
    # filtering — projects view is the complete history.
    groups = defaultdict(list)
    for s in sessions:
        cwd = s.get("cwd")
        if not cwd:
            continue
        groups[cwd].append(s)

    projects = []
    for cwd, items in groups.items():
        items.sort(key=lambda s: s.get("mtime", 0), reverse=True)
        newest = items[0]
        latest_title = newest.get("custom_title") or newest.get("first_prompt") or ""
        projects.append({
            "cwd": cwd,
            "label": project_label(cwd),
            "last_mtime": newest.get("mtime", 0),
            "session_count": len(items),
            "latest_title": latest_title,
        })

    projects.sort(key=lambda p: p["last_mtime"], reverse=True)
    return projects


def format_project_row(p, label_width=38, max_width=None):
    label = f"[{p['label']}]"
    if len(label) > label_width:
        label = label[: label_width - 1] + "]"
    label = label.ljust(label_width)
    time_ago = human_time_ago(p.get("last_mtime", 0)).rjust(8)
    date_str = absolute_date(p.get("last_mtime", 0))
    count = f"{p['session_count']:>3} sess"
    desc = p.get("latest_title") or p.get("cwd") or ""
    desc = re.sub(r"\[Image #\d+\]", "", desc)
    desc = re.sub(r"\s+", " ", desc).strip()
    desc = strip_leading_hashtag(desc)
    row = f"{label}  {time_ago}  {date_str}   {count}  {desc}"
    if max_width is not None and len(row) > max_width:
        row = row[: max_width - 1] + "…"
    return row


def render_project_rows(projects, for_fzf=False, max_width=None):
    # `projects` is DESC (newest first). fzf default layout puts the FIRST
    # input row at the bottom — so feed DESC for fzf. Plain stdout reads
    # top-down, so flip to ASC there.
    if for_fzf:
        return [
            f"__PROJECT__{idx}\t{format_project_row(p, max_width=max_width)}"
            for idx, p in enumerate(projects)
        ]
    return [format_project_row(p, max_width=max_width) for p in reversed(projects)]


def cmd_list(args):
    if args.sort == "projects":
        return cmd_list_projects(args)
    sessions = build_index(force_refresh=args.refresh)
    filtered = filter_sessions(sessions, args)
    displayed, overflow_by_group, total_overflow = apply_caps(filtered, args, sort_mode=args.sort)
    cols = shutil.get_terminal_size((100, 24)).columns
    lines = render_rows(displayed, overflow_by_group, total_overflow,
                        for_fzf=False, max_width=cols, sort_mode=args.sort)
    if not lines:
        print(
            "(no sessions match filters — try --all, --days N, or --include-empty)",
            file=sys.stderr,
        )
        return 0
    for line in lines:
        print(line)
    return 0


def cmd_list_projects(args):
    sessions = build_index(force_refresh=args.refresh)
    projects = build_projects(sessions)
    cols = shutil.get_terminal_size((100, 24)).columns
    lines = render_project_rows(projects, for_fzf=False, max_width=cols)
    if not lines:
        print("(no projects found)", file=sys.stderr)
        return 0
    print(
        "(projects view — Enter would open a new session in the picker)",
        file=sys.stderr,
    )
    for line in lines:
        print(line)
    return 0


def cmd_picker(args):
    try:
        subprocess.run(
            ["fzf", "--version"], capture_output=True, check=True
        )
    except (FileNotFoundError, subprocess.CalledProcessError):
        print("fzf not installed. Install with: brew install fzf", file=sys.stderr)
        print("Showing plain list instead:", file=sys.stderr)
        return cmd_list(args)

    initial_view = args.sort  # "projects" | "time" | "project"
    exec_quoted = shlex.quote(sys.argv[0])
    force_refresh = args.refresh

    # Loop so the picker re-appears after each launch — Esc is the way out.
    while True:
        sessions = build_index(force_refresh=force_refresh)
        # After the first pass, always rescan so sessions started via this picker show up.
        force_refresh = True
        filtered = filter_sessions(sessions, args)

        # Build all three views per pass so Ctrl-T cycling and Ctrl-R reset are
        # instant disk reads — no need to re-scan or re-filter on every keypress.
        # Projects view uses the FULL session list (no filters) — it's the complete
        # history of every cwd, intentionally bypassing --days / --include-empty.
        time_disp, time_ovg, time_to = apply_caps(list(filtered), args, sort_mode="time")
        proj_disp, proj_ovg, proj_to = apply_caps(list(filtered), args, sort_mode="project")
        time_lines = render_rows(time_disp, time_ovg, time_to, for_fzf=True, sort_mode="time")
        proj_lines = render_rows(proj_disp, proj_ovg, proj_to, for_fzf=True, sort_mode="project")

        projects = build_projects(sessions)
        projects_lines = render_project_rows(projects, for_fzf=True)

        if not time_lines and not proj_lines and not projects_lines:
            print(
                "(no sessions match filters — try --all, --days N, or --include-empty)",
                file=sys.stderr,
            )
            return 1

        view_lines = {
            "projects": projects_lines,
            "time": time_lines,
            "project": proj_lines,
        }
        initial_lines = view_lines[initial_view]

        # Four tempfiles: state tracks current view, the others cache rendered rows.
        state_fd, state_path = tempfile.mkstemp(prefix="sessions-state-", suffix=".txt")
        time_fd, time_path = tempfile.mkstemp(prefix="sessions-time-", suffix=".txt")
        proj_fd, proj_path = tempfile.mkstemp(prefix="sessions-proj-", suffix=".txt")
        projects_fd, projects_path = tempfile.mkstemp(prefix="sessions-projects-", suffix=".txt")
        try:
            with os.fdopen(state_fd, "w") as fh:
                fh.write(initial_view + "\n")
            with os.fdopen(time_fd, "w") as fh:
                fh.write("\n".join(time_lines))
            with os.fdopen(proj_fd, "w") as fh:
                fh.write("\n".join(proj_lines))
            with os.fdopen(projects_fd, "w") as fh:
                fh.write("\n".join(projects_lines))

            state_q = shlex.quote(state_path)
            time_q = shlex.quote(time_path)
            proj_q = shlex.quote(proj_path)
            projects_q = shlex.quote(projects_path)

            preview_cmd = f"{exec_quoted} --preview {{1}}"
            expand_cmd = f"{exec_quoted} --fzf-expand {{1}} --fzf-state {state_q}"
            toggle_cmd = f"{exec_quoted} --fzf-toggle {state_q} {time_q} {proj_q} {projects_q}"
            reset_cmd = f"{exec_quoted} --fzf-reset {state_q} {initial_view} {time_q} {proj_q} {projects_q}"

            # fzf shell-escapes {1} (single-quoted), so do NOT add extra quotes around it.
            space_bind = (
                f'space:transform:case {{1}} in '
                f'__OVERFLOW_*) echo "reload({expand_cmd})";; '
                f'esac'
            )
            toggle_bind = f"ctrl-t:reload({toggle_cmd})"
            reset_bind = f"ctrl-r:reload({reset_cmd})"

            result = subprocess.run(
                [
                    "fzf",
                    "--delimiter=\t",
                    "--with-nth=2..",
                    "--preview", preview_cmd,
                    "--preview-window=right:30%:wrap",
                    "--header=Enter resumes/opens — Space expands — Ctrl-T cycles view — Ctrl-R resets — Esc quits",
                    "--bind", space_bind,
                    "--bind", toggle_bind,
                    "--bind", reset_bind,
                    "--no-sort",
                ],
                input="\n".join(initial_lines),
                text=True,
                capture_output=True,
            )
        finally:
            for p in (state_path, time_path, proj_path, projects_path):
                try:
                    os.unlink(p)
                except OSError:
                    pass

        if result.returncode != 0:
            return 0  # user pressed Esc — quit the app
        selected = result.stdout.strip()
        if not selected:
            return 0

        key = selected.split("\t", 1)[0]
        if key.startswith("__OVERFLOW_"):
            print("Press Space to expand this group.", file=sys.stderr)
            continue

        if key.startswith("__PROJECT__"):
            try:
                idx = int(key[len("__PROJECT__"):])
            except ValueError:
                print(f"Bad project row: {key}", file=sys.stderr)
                continue
            if not 0 <= idx < len(projects):
                print(f"Project index out of range: {idx}", file=sys.stderr)
                continue
            start_new_session(projects[idx]["cwd"])
            continue

        session_id = key
        match = next(
            (s for s in sessions if s["session_id"] == session_id), None
        )
        if not match or not match.get("cwd"):
            print(f"Can't resume {session_id}: no cwd recorded", file=sys.stderr)
            continue

        resume_session(match["cwd"], session_id)
        continue


def launch_in_iterm(cwd, shell_cmd, log_label):
    if not Path(cwd).exists():
        print(f"cwd no longer exists: {cwd}", file=sys.stderr)
        return 1

    applescript_str = shell_cmd.replace("\\", "\\\\").replace('"', '\\"')
    script = (
        'tell application "iTerm"\n'
        '    activate\n'
        '    create window with default profile\n'
        '    tell current session of current window\n'
        f'        write text "{applescript_str}"\n'
        '    end tell\n'
        'end tell\n'
    )

    print(f"→ iTerm2: {log_label}")
    try:
        subprocess.run(["osascript", "-e", script], check=True)
        return 0
    except FileNotFoundError:
        print("osascript not found — are you on macOS?", file=sys.stderr)
        return 1
    except subprocess.CalledProcessError as e:
        print(
            f"iTerm2 launch failed (osascript exit {e.returncode}). Is iTerm2 installed?",
            file=sys.stderr,
        )
        return 1


def resume_session(cwd, session_id):
    shell_cmd = f"cd {shlex.quote(cwd)} && claude -r {shlex.quote(session_id)}"
    return launch_in_iterm(cwd, shell_cmd, f"cd {cwd} && claude -r {session_id}")


def start_new_session(cwd):
    shell_cmd = f"cd {shlex.quote(cwd)} && claude"
    return launch_in_iterm(cwd, shell_cmd, f"cd {cwd} && claude")


def cmd_preview(session_id):
    if session_id.startswith("__OVERFLOW_"):
        print("Hint: press Space to expand this group.")
        return 0
    for p in PROJECTS_DIR.glob(f"*/{session_id}.jsonl"):
        prompts = []
        last_usage = None
        try:
            with p.open() as fh:
                for line in fh:
                    try:
                        r = json.loads(line)
                    except json.JSONDecodeError:
                        continue
                    if r.get("type") == "assistant":
                        u = (r.get("message") or {}).get("usage")
                        if isinstance(u, dict):
                            last_usage = u
                    elif r.get("type") == "user" and not r.get("isMeta"):
                        if len(prompts) < 8:
                            txt = extract_message_text(r.get("message", {}))
                            if not is_noise_text(txt):
                                prompts.append(txt.strip()[:400])
        except OSError:
            pass

        context_tokens = 0
        if last_usage:
            context_tokens = (
                (last_usage.get("input_tokens") or 0)
                + (last_usage.get("cache_creation_input_tokens") or 0)
                + (last_usage.get("cache_read_input_tokens") or 0)
            )

        print(f"Session: {session_id}")
        info = scan_session(p)
        if info:
            print(f"Project: {info.get('project') or project_label(info.get('cwd'))}")
            print(f"cwd:     {info.get('cwd') or '(unknown)'}")
            print(f"Branch:  {info.get('git_branch') or '(none)'}")
            if last_usage:
                print(f"Tokens:  {context_tokens:,}")
            else:
                print("Tokens:  (none yet)")
            if info.get("custom_title"):
                print(f"Title:   {strip_leading_hashtag(info['custom_title'])}")
        print()
        for i, pr in enumerate(prompts, 1):
            print(f"─── prompt {i} " + "─" * 40)
            print(pr)
            print()
        if not prompts:
            print("(no user prompts found)")
        return 0
    print(f"Session {session_id} not found", file=sys.stderr)
    return 1


def cmd_name(session_id, title):
    for p in PROJECTS_DIR.glob(f"*/{session_id}.jsonl"):
        record = {
            "type": "custom-title",
            "customTitle": title,
            "sessionId": session_id,
        }
        with p.open("a") as fh:
            fh.write(json.dumps(record) + "\n")
        print(f"Set title for {session_id}: {title}")
        if CACHE_FILE.exists():
            try:
                CACHE_FILE.unlink()
            except OSError:
                pass
        return 0
    print(f"Session {session_id} not found", file=sys.stderr)
    return 1


def cmd_fzf_expand(token, state_path=None):
    # Called by fzf's space-binding to replace the picker contents with
    # an expanded view (project-filtered or unfiltered). Outputs fzf-formatted
    # rows on stdout. Unknown tokens produce empty output (fzf treats this as
    # an empty list, which we avoid by only binding space to overflow rows).
    sessions = build_index()

    class _Args:
        all = False
        days = None
        per_group = 0
        include_empty = False
        project = None
        refresh = False

    args = _Args()
    if token.startswith("__OVERFLOW_PROJECT__"):
        args.project = token[len("__OVERFLOW_PROJECT__"):]
        args.all = True
    elif token == "__OVERFLOW_GLOBAL__":
        args.all = True
    else:
        return 0

    # Preserve the user's current sort mode when expanding. Only session views
    # (time / project) have overflow rows — if the state is "projects" we fall
    # back to project clustering as a safe default (this branch shouldn't fire
    # because Space is only bound for __OVERFLOW_* tokens).
    sort_mode = "project"
    if state_path:
        try:
            sort_mode = (Path(state_path).read_text().strip() or "project")
        except OSError:
            pass
    if sort_mode not in ("time", "project"):
        sort_mode = "project"

    filtered = filter_sessions(sessions, args)
    displayed, overflow_by_group, total_overflow = apply_caps(filtered, args, sort_mode=sort_mode)
    lines = render_rows(displayed, overflow_by_group, total_overflow,
                        for_fzf=True, sort_mode=sort_mode)
    sys.stdout.write("\n".join(lines))
    return 0


CYCLE_NEXT = {"projects": "time", "time": "project", "project": "projects"}


def cmd_fzf_toggle(state_path, time_path, project_path, projects_path):
    # Cycle the current view through projects → time → project → projects and
    # emit the cached rows for the new view. All caches are pre-rendered at
    # picker launch.
    try:
        cur = Path(state_path).read_text().strip()
    except OSError:
        cur = "projects"
    new = CYCLE_NEXT.get(cur, "projects")
    cache = {
        "time": time_path,
        "project": project_path,
        "projects": projects_path,
    }[new]
    try:
        Path(state_path).write_text(new + "\n")
    except OSError:
        pass
    try:
        sys.stdout.write(Path(cache).read_text())
    except OSError:
        pass
    return 0


def cmd_fzf_reset(state_path, initial_view, time_path, project_path, projects_path):
    # Restore the launch-time view AND reset the toggle state so subsequent
    # Ctrl-T presses behave correctly.
    try:
        Path(state_path).write_text(initial_view + "\n")
    except OSError:
        pass
    cache = {
        "time": time_path,
        "project": project_path,
        "projects": projects_path,
    }.get(initial_view, projects_path)
    try:
        sys.stdout.write(Path(cache).read_text())
    except OSError:
        pass
    return 0


def cmd_resume(session_id):
    for p in PROJECTS_DIR.glob(f"*/{session_id}.jsonl"):
        info = scan_session(p)
        if info and info.get("cwd"):
            return resume_session(info["cwd"], session_id)
    print(f"Session {session_id} not found or has no recorded cwd", file=sys.stderr)
    return 1


def main():
    parser = argparse.ArgumentParser(
        description="Browse and resume Claude Code sessions across projects.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
Examples:
  sessions                        interactive fzf picker — projects view (default)
  sessions --sort time            picker, flat sessions list by recency
  sessions --sort project         picker, sessions grouped by project folder
  sessions --list                 plain output, projects view (default)
  sessions --list --sort time     plain output, flat sessions by recency
  sessions --list --sort project  plain output, sessions grouped by project
  sessions --today                last 24h only (session views)
  sessions --days 30              last 30 days (session views)
  sessions --project my-cfo-hub   filter by project substring (session views)
  sessions --all                  show everything (no filters, session views)
  sessions --name <uuid> "title"  retroactively name a session
  sessions --resume <uuid>        resume session by UUID from any cwd

In the picker, Ctrl-T cycles through projects → time → project views.
Enter on a project row opens a fresh Claude Code session in that cwd.
""",
    )
    parser.add_argument("--list", action="store_true", help="Plain output (no fzf).")
    parser.add_argument("--sort", choices=["projects", "time", "project"], default="projects",
                        help="View mode: 'projects' (one row per cwd, complete history; default), "
                             "'time' (flat sessions, newest at bottom), or "
                             "'project' (sessions clustered by project folder).")
    parser.add_argument("--all", action="store_true", help="Disable all filters.")
    parser.add_argument("--days", type=int, default=56,
                        help="Recency window in days (default 56, ~8 weeks).")
    parser.add_argument("--today", action="store_true", help="Shortcut for --days 1.")
    parser.add_argument("--per-group", type=int, default=10,
                        help="Max sessions per project in project view (0=unlimited, default 10).")
    parser.add_argument("--include-empty", action="store_true",
                        help="Include aborted/empty sessions.")
    parser.add_argument("--project", type=str, help="Filter by project substring.")
    parser.add_argument("--refresh", action="store_true",
                        help="Ignore cache, rescan all JSONLs.")
    parser.add_argument("--name", nargs=2, metavar=("UUID", "TITLE"),
                        help="Set a customTitle on an existing session.")
    parser.add_argument("--resume", metavar="UUID", help="Resume a session by UUID.")
    parser.add_argument("--preview", metavar="UUID", help=argparse.SUPPRESS)
    parser.add_argument("--fzf-expand", metavar="TOKEN", help=argparse.SUPPRESS)
    parser.add_argument("--fzf-state", metavar="PATH", help=argparse.SUPPRESS)
    parser.add_argument("--fzf-toggle", nargs=4,
                        metavar=("STATE", "TIME_PATH", "PROJECT_PATH", "PROJECTS_PATH"),
                        help=argparse.SUPPRESS)
    parser.add_argument("--fzf-reset", nargs=5,
                        metavar=("STATE", "INITIAL_VIEW", "TIME_PATH", "PROJECT_PATH", "PROJECTS_PATH"),
                        help=argparse.SUPPRESS)

    args = parser.parse_args()

    if args.today:
        args.days = 1

    if args.preview:
        return cmd_preview(args.preview)
    if args.fzf_expand:
        return cmd_fzf_expand(args.fzf_expand, args.fzf_state)
    if args.fzf_toggle:
        return cmd_fzf_toggle(*args.fzf_toggle)
    if args.fzf_reset:
        return cmd_fzf_reset(*args.fzf_reset)
    if args.name:
        return cmd_name(args.name[0], args.name[1])
    if args.resume:
        return cmd_resume(args.resume)
    if args.list:
        return cmd_list(args)
    return cmd_picker(args)


if __name__ == "__main__":
    try:
        sys.exit(main() or 0)
    except KeyboardInterrupt:
        sys.exit(130)
